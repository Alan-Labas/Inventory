JWT_SECRET=change-me
JWT_EXPIRATION=change-me

MYSQL_DATABASE=change-me
MYSQL_USER=change-me
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=rootpassword

SPRING_DATASOURCE_URL=change-me
SPRING_DATASOURCE_URL_LOCAL=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_PROFILES_ACTIVE=docker

# Production URLs — set these to your real domain on the droplet.
# APP_FRONTEND_URL is used in confirmation email links; APP_CORS_ORIGINS
# must include the domain the browser loads the app from.
APP_FRONTEND_URL=https://your-domain
APP_CORS_ORIGINS=https://your-domain

SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_NAME=Inventory
SPRING_MAIL_FROM=your-email@example.com
SPRING_MAIL_USERNAME=your-smtp-user
SPRING_MAIL_PASSWORD=change-me
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

